#!/usr/bin/env bash
#
# CLI launcher for claude-code-models projects
# Reads .claude/launch.json and starts the selected configuration.
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LAUNCH_JSON="$SCRIPT_DIR/.claude/launch.json"

if [[ ! -f "$LAUNCH_JSON" ]]; then
  echo "Error: $LAUNCH_JSON not found" >&2
  exit 1
fi

# Check for jq
if ! command -v jq &>/dev/null; then
  echo "Error: jq is required. Install with: brew install jq (macOS) or apt install jq (Linux)" >&2
  exit 1
fi

NUM_CONFIGS=$(jq '.configurations | length' "$LAUNCH_JSON")

if [[ "$NUM_CONFIGS" -eq 0 ]]; then
  echo "No launch configurations found in $LAUNCH_JSON" >&2
  exit 1
fi

# --- Usage ---
usage() {
  echo "Usage: ./launch [name]"
  echo ""
  echo "Available configurations:"
  for i in $(seq 0 $((NUM_CONFIGS - 1))); do
    name=$(jq -r ".configurations[$i].name" "$LAUNCH_JSON")
    exe=$(jq -r ".configurations[$i].runtimeExecutable" "$LAUNCH_JSON")
    port=$(jq -r ".configurations[$i].port // empty" "$LAUNCH_JSON")
    args=$(jq -r ".configurations[$i].runtimeArgs | join(\" \")" "$LAUNCH_JSON")
    printf "  %-20s %s %s" "$name" "$exe" "$args"
    [[ -n "$port" ]] && printf "  (port %s)" "$port"
    echo
  done
}

# --- Find config by name ---
find_config() {
  local target="$1"
  for i in $(seq 0 $((NUM_CONFIGS - 1))); do
    name=$(jq -r ".configurations[$i].name" "$LAUNCH_JSON")
    if [[ "$name" == "$target" ]]; then
      echo "$i"
      return
    fi
  done
  echo "-1"
}

# --- Launch a configuration ---
run_config() {
  local idx="$1"
  local name exe port
  name=$(jq -r ".configurations[$idx].name" "$LAUNCH_JSON")
  exe=$(jq -r ".configurations[$idx].runtimeExecutable" "$LAUNCH_JSON")
  port=$(jq -r ".configurations[$idx].port // empty" "$LAUNCH_JSON")

  # Build args array
  local args=()
  while IFS= read -r arg; do
    args+=("$arg")
  done < <(jq -r ".configurations[$idx].runtimeArgs[]" "$LAUNCH_JSON")

  echo "Launching: $name"
  echo "  Command: $exe ${args[*]}"
  [[ -n "$port" ]] && echo "  Port:    $port"
  echo ""

  exec "$exe" "${args[@]}"
}

# --- Main ---
if [[ $# -eq 0 ]]; then
  if [[ "$NUM_CONFIGS" -eq 1 ]]; then
    run_config 0
  else
    usage
    echo ""
    read -rp "Enter configuration name: " choice
    idx=$(find_config "$choice")
    if [[ "$idx" == "-1" ]]; then
      echo "Error: Unknown configuration '$choice'" >&2
      exit 1
    fi
    run_config "$idx"
  fi
else
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -l|--list)
      for i in $(seq 0 $((NUM_CONFIGS - 1))); do
        jq -r ".configurations[$i].name" "$LAUNCH_JSON"
      done
      exit 0
      ;;
    *)
      idx=$(find_config "$1")
      if [[ "$idx" == "-1" ]]; then
        echo "Error: Unknown configuration '$1'" >&2
        echo ""
        usage
        exit 1
      fi
      run_config "$idx"
      ;;
  esac
fi
